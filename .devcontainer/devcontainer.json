// Reference at 
// https://containers.dev/implementors/json_reference/

{
  "name": "dev_container_template",
  "dockerComposeFile": "../compose.yml",
  "service": "server", // service that runs the app
  "workspaceFolder": "/project", //path inside the container
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "terminal.integrated.env.linux": {
          "PYTHONPATH": "/app/src"
        }
      }
    }
  },
  "forwardPorts": [5173] //An array of port numbers or "host:port" values
} 